#include <iostream>
#include "Header.h"
using namespace std;



int main()
{
	int rows, cols;
	cout << "Enter rows ";
	cin >> rows;
	cout << "Enter cols ";
	cin >> cols;

	int** arr2D = new int* [rows];
	for (int i = 0; i < rows; i++)
	{
		arr2D[i] = new int[cols];
	}


	srand(time(0));

	Fill2darr(arr2D, rows, cols);
	Print2Darr(arr2D, rows, cols);
	cout << ProdKvit(arr2D, rows, cols);
	Emtrow(arr2D, rows, cols);
	EmptyCols(arr2D, rows, cols);
	SumRow(arr2D, rows, cols);

	for (int i = 0; i < rows; i++)
	{
		delete[] arr2D[i];
	}

	delete[] arr2D;
}





#pragma once
using namespace std;

void Fill2darr(int** arr, int rows, int cols)
{
	for (int i = 0; i < rows; i++)
	{
		for (int j = 0; j < cols; j++)
		{
			arr[i][j] = rand() % 2;
		}
	}
}
void Print2Darr(int** arr, int rows, int cols) {
	for (int i = 0; i < rows; i++)
	{
		for (int j = 0; j < cols; j++)
		{
			cout << arr[i][j] << ' ';
		}
		cout << endl;
	}
}

int ProdKvit(int** arr, int rows, int cols)
{
	int prod = 0;
	for (int i = 0; i < rows; i++)
	{
		for (int j = 0; j < cols; j++)
		{
			if (arr[i][j] == 1)
			{
				prod++;
			}
		}
	}

	return prod;
}

void Emtrow(int** arr, int rows, int cols)
{
	for (int i = 0; i < rows; i++)
	{
		bool isfeel = true;
		for (int j = 0; j < cols; j++)
		{
			if (arr[i][j] != 0)
			{
				isfeel = false;
				break;
			}
		}
		if (isfeel == true)
		{
			cout << i << " Empty  " << endl;
		}
	}
}


void EmptyCols(int** arr, int rows, int cols)
{
	bool isfree = true;
	for (int j = 0; j < cols; j++)
	{
		isfree = true;
		for (int i = 0; i < rows; i++)
		{
			if (arr[i][j] != 0)
			{
				isfree = false;
				break;
			}
		}
		if (isfree == true)
		{
			cout << j << " Empty col " << endl;
		}
	}
}


void SumRow(int** arr, int rows, int cols)
{
	for (int i = 0; i < rows; i++)
	{
		int sum = 0;
		for (int j = 0; j < cols; j++)
		{
			if (arr[i][j] == 1)
			{
				sum++;
			}
		}
		cout <<  i << sum << endl;
	}
}
