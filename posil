#pragma once
#include <iostream>
using namespace std;

int elements(int* arr, int size) {
    int count = 0;

    for (int i = 0; i < size; i++) {
        if (arr[i] % 2 != 0 || arr[i] == 0) {
            count++;
        }
    }

    return count;
}

int* createNewArray(int* arr, int size, int& newSize) {
    newSize = elements(arr, size);

    int* newArr = new int[newSize];

    int j = 0;
    for (int i = 0; i < size; i++) {
        if (arr[i] % 2 != 0 || arr[i] == 0) {
            newArr[j] = arr[i];
            j++;
        }
    }

    return newArr;
}
