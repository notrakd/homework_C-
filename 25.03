#include <iostream>

int compareStrings(char s1[], char s2[]) {
    int i = 0;
    while (s1[i] != '\0' || s2[i] != '\0') {
        char c1 = s1[i];
        char c2 = s2[i];
        if (c1 >= 'A' && c1 <= 'Z') {
            c1 = c1 + 32;
        }
        if (c2 >= 'A' && c2 <= 'Z') {
            c2 = c2 + 32;
        }
        if (c1 > c2) return 1;
        if (c1 < c2) return -1;

        i++;
    }

    return 0;
}

int main() {
    char str1[] = "Boцц";
    char str2[] = "bob";

    int result = compareStrings(str1, str2);
    std::cout << "Result: " << result << std::endl;

    return 0;
}
