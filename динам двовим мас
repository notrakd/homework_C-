#include <iostream>
using namespace std;

void print2Darr(int** arr, int rows, int cols) {
	for (int i = 0; i < rows; i++)
	{
		for (int j = 0; j < cols; j++)
		{
			cout << arr[i][j] << ' ';
		}
		cout << endl;
	}
}


int* Sum(int** arr, int rows, int cols)
{
    int* res = new int[rows];

    for(int i = 0; i < rows; i++)
    {
        res[i] = 0;
        for(int j = 0; j < cols; j++)
        {
            res[i] += arr[i][j];
        }
    }

    return res;
}


int main()
{
	int rows, cols;
	cout << "Enter Rows";
	cin >> rows;
	cout << "Enter cols";
	cin >> cols;
	int** arr2D = new int* [rows];
	for (int i = 0; i < rows; i++)
	{
		arr2D[i] = new int[cols];
	}

	srand(time(0));
	for (int i = 0; i < rows; i++)
	{
		for (int j = 0; j < cols; j++)
		{
			arr2D[i][j] = rand() % 10;
		}
	}
	print2Darr(arr2D, rows, cols);
    int* sum = Sum(arr2D, rows, cols);

    for(int i = 0; i < rows; i ++)
    {
        cout << sum[i];
    }

	for (int i = 0; i < rows; i++)
	{
		delete[] arr2D[i];
	}

	delete[] arr2D;
}
