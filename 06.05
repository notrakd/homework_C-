#include <iostream>
#include <cctype>

using namespace std;

int main() {
    char filename[50];
    cout << "Enter File's name: ";
    cin >> filename;

    FILE* file = fopen(filename, "r");
    if (!file) {
        cout << "Error. Cannot open file '" << filename << "'\n";
        return 1;
    }

    int lines   = 0;
    int spaces  = 0;
    int letters = 0;
    int words   = 0;

    int ch;
    bool inWord = false;

    while ((ch = fgetc(file)) != EOF) {
        if (ch == '\n') {
            ++lines;
            inWord = false;
            continue;
        }

        if (isalpha(ch))  ++letters;
        if (ch == ' ' || ch == '\t') ++spaces;

        if (!isspace(ch) && !inWord) {
            ++words;
            inWord = true;
        } else if (isspace(ch)) {
            inWord = false;
        }
    }

    fclose(file);
    
    cout << endl;
    cout << "Stat block:" << filename;
    cout << "Кількість рядків : " << lines   << endl;
    cout << "Кількість пробілів : " << spaces  << endl;
    cout << "Кількість літер : " << letters << endl;
    cout << "Кількість слів : " << words   << endl;

    return 0;
}
