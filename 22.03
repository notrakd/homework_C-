#include <iostream>
using namespace std;

char* Strfin(char* str, char* podstr)
{
    for (int i = 0; str[i] != '\0'; i++)
    {
        int j = 0;

        while (podstr[j] != '\0')
        {
            if (str[i + j] != podstr[j])
                break;

            j++;
        }

        if (podstr[j] == '\0')
        {
            return &str[i];
        }
    }

    return nullptr;
}

int main()
{
    char str[] = "Hello world";
    char podstr[] = "world";

    char* result = Strfin(str, podstr);

    if (result != nullptr)
    {
       cout << result << endl;
    }
    else
    {
        cout << "not found" << endl;
    }

    return 0;
}
