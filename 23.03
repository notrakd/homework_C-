#include <iostream>
using namespace std;

int StringToNumber(char* str) {
    int num = 0;
    int sign = 1;
    int i = 0;

    if (str[0] == '-') {
        sign = -1;
        i = 1;
    }

    while (str[i] >= '0' && str[i] <= '9') {
        num = num * 10 + (str[i] - '0');
        i++;
    }

    return num * sign;
}

int main() {
    char str1[] = "12345";
    char str2[] = "-6789";

    cout << str1 <<  StringToNumber(str1) << endl;
    cout << str2 <<  StringToNumber(str2) << endl;

    return 0;
}
